{
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px"
        },
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "color": "#F2EFDE",
                    "name": "Beige Clair (Principal)"
                },
                {
                    "slug": "contrast",
                    "color": "#7A7C57",
                    "name": "Vert Olive (Contraste)"
                },
                {
                    "slug": "primary",
                    "color": "#D8B990",
                    "name": "Doré Sable (Primaire)"
                },
                {
                    "slug": "secondary-1",
                    "color": "#949C81",
                    "name": "Sauge (Secondaire)"
                },
                {
                    "slug": "secondary-2",
                    "color": "#DDA15E",
                    "name": "Ocre Doux (Secondaire)"
                },
                {
                    "slug": "secondary-3",
                    "color": "#CF8C40",
                    "name": "Ocre Terre (Secondaire)"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "\"Caviar Dreams\", sans-serif",
                    "name": "Caviar Dreams",
                    "slug": "primary-font"
                },
                {
                    "fontFamily": "\"Hiragino Kaku Gothic\", sans-serif",
                    "name": "Hiragino Kaku",
                    "slug": "secondary-font"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "0.9rem",
                    "name": "Petit"
                },
                {
                    "slug": "medium",
                    "size": "1.1rem",
                    "name": "Moyen"
                },
                {
                    "slug": "large",
                    "size": "1.75rem",
                    "name": "Grand"
                },
                {
                    "slug": "x-large",
                    "size": "2.5rem",
                    "name": "Très Grand"
                }
            ]
        }
    },
    "styles": {
        "css": ".wp-block-group:has(> header) { min-height:100vh; display:flex; flex-direction:column; } .wp-block-group:has(> header) > main { flex: 1 1 auto; }",
  
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--secondary-font)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.6"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                },
                "typography": {
                    "textDecoration": "none"
                }
            },
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--primary-font)",
                    "fontWeight": "700"
                }
            }
        }
    }
}