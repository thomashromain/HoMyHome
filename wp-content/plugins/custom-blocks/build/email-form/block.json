{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "custom/modular-email-block",
  "version": "0.1.0",
  "title": "Modular Email Block",
  "category": "widgets",
  "attributes": {
    "fields": {
      "type": "array",
      "default": [],
      "items": {
        "title": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        }
      }
    }
  },
  "supports": {
    "html": false
  },
  "textdomain": "modular-email",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}